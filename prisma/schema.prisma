generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== AUTH & USERS ====================

model PendingUser {
  id              String        @id @default(uuid())
  name            String
  email           String        @unique
  phone           String?
  passwordHash    String
  plan            String
  couponCode      String?
  originalPrice   Float
  finalPrice      Float
  acceptedTerms   Boolean       @default(false)
  acceptedTermsAt DateTime?
  mpPreferenceId  String?       @unique
  mpPaymentId     String?       @unique
  status          PendingStatus @default(AWAITING_PAYMENT)
  createdAt       DateTime      @default(now())
}

enum PendingStatus {
  AWAITING_PAYMENT
  PAID
  EXPIRED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String
  name                String
  phone               String?
  avatarUrl           String?   @db.Text
  level               Level     @default(INICIANTE)
  role                Role      @default(MEMBER)
  subscriptionStatus  SubStatus @default(ACTIVE)
  subscriptionPlan    String
  subscriptionEnd     DateTime?
  mpPaymentId         String?   @unique
  couponUsed          String?
  amountPaid          Float?
  acceptedTerms       Boolean   @default(true)
  acceptedTermsAt     DateTime?
  onboardingDone      Boolean   @default(false)
  onboardingAnswer    String?   @db.Text
  blockReason         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  posts               Post[]
  comments            Comment[]
  reactions           Reaction[]
  products            UserProduct[]
  progress            UserProgress[]
  clubMembers         ClubMember[]
}

enum Level {
  INICIANTE
  INTERMEDIARIO
  AVANCADO
}

enum Role {
  MEMBER
  ADMIN
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  @@index([email])
}

// ==================== CLUBES (conteúdo por plano) ====================

model Club {
  id              String       @id @default(uuid())
  slug            String       @unique
  name            String
  description     String       @db.Text
  imageUrl        String?      @db.Text
  minPlan         String       @default("monthly")  // monthly, quarterly, yearly, premium
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  courses         Course[]
  members         ClubMember[]
}

model ClubMember {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  clubId    String
  club      Club     @relation(fields: [clubId], references: [id])
  joinedAt  DateTime @default(now())
  @@unique([userId, clubId])
}

// ==================== CURSOS & AULAS ====================

model Course {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  imageUrl    String?  @db.Text
  level       Level    @default(INICIANTE)
  clubId      String?
  club        Club?    @relation(fields: [clubId], references: [id])
  isFree      Boolean  @default(false)
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
}

model Lesson {
  id          String   @id @default(uuid())
  slug        String
  title       String
  description String?  @db.Text
  videoUrl    String?  @db.Text
  materialUrl String?  @db.Text       // PDF/material da aula
  materialName String?                // nome do arquivo
  content     String?  @db.LongText
  duration    Int?                    // minutos
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sortOrder   Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  progress    UserProgress[]

  @@unique([courseId, slug])
}

// ==================== PROGRESSO ====================

model UserProgress {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  lessonId    String
  lesson      Lesson    @relation(fields: [lessonId], references: [id])
  completed   Boolean   @default(false)
  completedAt DateTime?
  watchTime   Int?                     // segundos assistidos
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@unique([userId, lessonId])
}

// ==================== CONTEÚDO SEMANAL ====================

model WeekContent {
  id            String    @id @default(uuid())
  weekNumber    Int       @unique
  title         String
  description   String    @db.Text
  level         Level
  musicUrl      String    @db.Text
  videoUrl      String    @db.Text
  vocabulary    Json
  prompts       Json
  exercise      String?   @db.Text
  challengeText String    @db.Text
  isActive      Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  meetings      Meeting[]
}

model Meeting {
  id               String       @id @default(uuid())
  title            String
  level            Level
  scheduledAt      DateTime
  duration         Int          @default(60)
  meetingUrl       String       @db.Text
  maxParticipants  Int          @default(8)
  description      String?      @db.Text
  weekContentId    String?
  weekContent      WeekContent? @relation(fields: [weekContentId], references: [id])
  isPremiumOnly    Boolean      @default(false)
  city             String?
  address          String?      @db.Text
  createdAt        DateTime     @default(now())
}

// ==================== COMUNIDADE ====================

model Post {
  id          String    @id @default(uuid())
  content     String    @db.Text
  type        PostType  @default(PRATICA)
  audioUrl    String?   @db.Text
  imageUrl    String?   @db.Text
  isPinned    Boolean   @default(false)
  isFeatured  Boolean   @default(false)
  isChallenge Boolean   @default(false)
  level       Level?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  comments    Comment[]
  reactions   Reaction[]
  createdAt   DateTime  @default(now())
}

enum PostType {
  PRATICA
  DUVIDA
  DISCUSSAO
  DESAFIO
}

model Comment {
  id        String    @id @default(uuid())
  content   String    @db.Text
  audioUrl  String?   @db.Text
  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation(fields: [authorId], references: [id])
  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")
  createdAt DateTime  @default(now())
}

model Reaction {
  id     String @id @default(uuid())
  type   String @default("like")
  userId String
  user   User   @relation(fields: [userId], references: [id])
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  @@unique([userId, postId])
}

// ==================== CUPONS ====================

model Coupon {
  id              String       @id @default(uuid())
  code            String       @unique
  discountType    DiscountType
  discountValue   Float
  maxUses         Int?
  currentUses     Int          @default(0)
  minPlanInterval String?
  validFrom       DateTime     @default(now())
  validUntil      DateTime?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// ==================== EVENTOS PREMIUM ====================

model PremiumEvent {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  city        String
  date        DateTime
  maxSpots    Int
  spotsLeft   Int
  imageUrl    String?  @db.Text
  createdAt   DateTime @default(now())
}

// ==================== PRODUTOS DIGITAIS ====================

model DigitalProduct {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  price       Float
  imageUrl    String?  @db.Text
  fileUrl     String?  @db.Text     // URL do arquivo para download
  fileName    String?               // nome original do arquivo
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchases   UserProduct[]
}

// Compra de produto digital (sem necessidade de conta)
model ProductPurchase {
  id               String   @id @default(uuid())
  email            String
  name             String
  phone            String?
  digitalProductId String
  amountPaid       Float
  status           PurchaseStatus @default(PENDING)
  downloadToken    String   @unique
  downloadCount    Int      @default(0)
  createdAt        DateTime @default(now())

  @@index([email])
  @@index([downloadToken])
}

enum PurchaseStatus {
  PENDING
  PAID
  EXPIRED
}

// Compra vinculada a usuário (quando tem conta)
model UserProduct {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id])
  digitalProductId String
  digitalProduct   DigitalProduct @relation(fields: [digitalProductId], references: [id])
  paymentMethod    String?
  paymentId        String?
  amountPaid       Float?
  purchasedAt      DateTime       @default(now())
  @@unique([userId, digitalProductId])
}

// ==================== NEWSLETTER ====================

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  source    String?  @default("website")
  createdAt DateTime @default(now())
}
